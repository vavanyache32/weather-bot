# --- Required ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=8723588566:AAGMz9JpKYkkpNAQ7F23teRiOXHlVSwPfvI

# Chat ID where scheduled updates are sent (user, group or channel ID).
# To find yours: message @userinfobot, or forward a message from your target
