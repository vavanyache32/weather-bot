# --- Optional but recommended ---
# Yandex.Weather API key (https://yandex.ru/dev/weather/)
# If omitted, the bot runs on NOAA only and logs a warning for Yandex.
YANDEX_API_KEY=c5be39bd-9dd7-44b8-acb1-56c8ee2e221b

# --- Optional overrides ---
# Poll interval in seconds (default: 1800 = 30 min)
# POLL_INTERVAL_SECONDS=60

# Log level: DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO

# Where to persist last temp / daily max (JSON)
# STATE_FILE=state.json

# NOAA requires an identifying User-Agent with contact info.
# HTTP_USER_AGENT=weatherapp-telegram-bot (https://your.site; you@example.com)

