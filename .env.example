# --- Required ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AA...your-token-here

# Chat ID where scheduled updates are sent (user, group or channel ID).
# To find yours: message @userinfobot, or forward a message from your target
# chat to @JsonDumpBot.
TELEGRAM_CHAT_ID=123456789

# --- Optional but recommended ---
# Yandex.Weather API key (https://yandex.ru/dev/weather/)
# If omitted, the bot runs on NOAA + Open-Meteo and logs a warning for Yandex.
YANDEX_API_KEY=your-yandex-api-key

# --- Optional LLM analysis ---
# If LLM_API_KEY is not set, the bot works without the 🧠 Анализ block.
# Defaults below are for Moonshot/Kimi (OpenAI-compatible).
# Swap to OpenAI / DeepSeek / local llama.cpp just by changing these three.
LLM_API_KEY=
LLM_BASE_URL=https://api.moonshot.ai/v1
LLM_MODEL=kimi-latest
# LLM_TIMEOUT=120   # thinking models (kimi-k2.6, o1) can take 60–90s; auto-retries are disabled

# --- Proxy for Telegram API (e.g. if blocked by ISP) ---
# Supports http://, https://, socks5://, socks4://
# For Tor: install `tor`, then use TELEGRAM_PROXY=socks5://127.0.0.1:9050
# TELEGRAM_PROXY=

# --- Optional overrides ---
# Poll interval in seconds (default: 60 = 1 min)
POLL_INTERVAL_SECONDS=60
# How many days to include in /forecast (default 5)
# FORECAST_DAYS=5
# How often to refresh the ensemble forecast + LLM (default 3600 = 1h)
# FORECAST_REFRESH_SECONDS=3600

# Log level: DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO

# Where to persist last temp / daily max / cached forecast (JSON)
# STATE_FILE=state.json

# NOAA requires an identifying User-Agent with contact info.
# HTTP_USER_AGENT=weatherapp-telegram-bot (https://your.site; you@example.com)

# --- New observation sources ---
# OGIMET SYNOP (station 27611 = Vnukovo). Enabled by default.
# OGIMET_ENABLED=true
# OGIMET_STATION_ID=27611
# OGIMET_INTERVAL_SECONDS=600
# OGIMET_TIMEOUT_SECONDS=15

# IEM ASOS (aggregates METAR + SPECI). Enabled by default.
# IEM_ENABLED=true
# IEM_STATION=UUWW
# IEM_NETWORK=RU__ASOS
# IEM_INTERVAL_SECONDS=300
# IEM_TIMEOUT_SECONDS=15

# WIS 2.0 MQTT (push, optional). Disabled by default — requires paho-mqtt + eccodes.
# WIS2_ENABLED=false
# WIS2_BROKER=mqtts://globalbroker.meteo.fr:8883
# WIS2_TOPIC=origin/a/wis2/ru-roshydromet/data/core/weather/surface-based-observations/synop
# WIS2_USERNAME=everyone
# WIS2_PASSWORD=everyone
# WIS2_WIGOS_ID=0-20000-0-27611

# --- Forecast pipeline + SQLite ---
# DB_PATH=weather.db
# FORECAST_DETAILED_REFRESH_SECONDS=3600
# FORECAST_MODELS_ENABLED=true
# FORECAST_ENSEMBLE_ENABLED=true
# MET_NORWAY_ENABLED=true
# MET_NORWAY_INTERVAL_SECONDS=1800
# TAF_ENABLED=true
# TAF_INTERVAL_SECONDS=1800
# METEOINFO_ENABLED=false
# METEOINFO_INTERVAL_SECONDS=10800

# --- Alerts ---
# ALERTS_ENABLED=true
# ALERTS_CONFIG_PATH=alerts.yaml
# WEBHOOK_URL=
# EMAIL_ENABLED=false
