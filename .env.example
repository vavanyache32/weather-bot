# --- Required ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AA...your-token-here

# Chat ID where scheduled updates are sent (user, group or channel ID).
# To find yours: message @userinfobot, or forward a message from your target
# chat to @JsonDumpBot.
TELEGRAM_CHAT_ID=123456789

# --- Optional but recommended ---
# Yandex.Weather API key (https://yandex.ru/dev/weather/)
# If omitted, the bot runs on NOAA + Open-Meteo and logs a warning for Yandex.
YANDEX_API_KEY=your-yandex-api-key

# --- Optional LLM analysis ---
# If LLM_API_KEY is not set, the bot works without the 🧠 Анализ block.
# Defaults below are for Moonshot/Kimi (OpenAI-compatible).
# Swap to OpenAI / DeepSeek / local llama.cpp just by changing these three.
LLM_API_KEY=
LLM_BASE_URL=https://api.moonshot.ai/v1
LLM_MODEL=kimi-latest
# LLM_TIMEOUT=120   # thinking models (kimi-k2.6, o1) can take 60–90s; auto-retries are disabled

# --- Proxy for Telegram API (e.g. if blocked by ISP) ---
# Supports http://, https://, socks5://, socks4://
# For Tor: install `tor`, then use TELEGRAM_PROXY=socks5://127.0.0.1:9050
# TELEGRAM_PROXY=

# --- Optional overrides ---
# Poll interval in seconds (default: 1800 = 30 min)
# POLL_INTERVAL_SECONDS=1800
# How many days to include in /forecast (default 5)
# FORECAST_DAYS=5
# How often to refresh the ensemble forecast + LLM (default 3600 = 1h)
# FORECAST_REFRESH_SECONDS=3600

# Log level: DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO

# Where to persist last temp / daily max / cached forecast (JSON)
# STATE_FILE=state.json

# NOAA requires an identifying User-Agent with contact info.
# HTTP_USER_AGENT=weatherapp-telegram-bot (https://your.site; you@example.com)
